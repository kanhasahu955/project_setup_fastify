generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client-mongodb"
}

datasource db {
  provider = "mongodb"
  // Use a single DATABASE_URL env var for all providers by default
  url      = env("DATABASE_URL")
}

/////////////////////////
// ENUMS
/////////////////////////

enum UserRole {
  BUYER
  OWNER
  AGENT
  BUILDER
  CHANNEL_PARTNER
  ADMIN
}

enum LeadSource {
  CHAT
  CALL
  AI_ASSISTANT
  DIRECT_ENQUIRY
}

enum LeadStatus {
  NEW
  CONTACTED
  SITE_VISIT
  CLOSED
  LOST
}

enum PlanType {
  FREE
  AGENT_BASIC 
  AGENT_PRO
  BUILDER_PRO
  CHANNEL_PARTNER_PRO
}

enum BillingInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ListingType {
  SALE
  RENT
  LEASE
}

enum PropertyCondition {
  NEW
  RESALE
  UNDER_CONSTRUCTION
  READY_TO_MOVE
}

enum PropertyType {
  APARTMENT
  INDEPENDENT_HOUSE
  VILLA
  STUDIO_APARTMENT
  PENTHOUSE
  BUILDER_FLOOR
  OFFICE_SPACE
  SHOP
  SHOWROOM
  WAREHOUSE
  INDUSTRIAL_BUILDING
  CO_WORKING
  RESIDENTIAL_PLOT
  COMMERCIAL_PLOT
  AGRICULTURAL_LAND
  PG
  HOSTEL
}

enum ListingStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  UNDER_REVIEW
  SOLD
  RENTED
  EXPIRED
  REJECTED
  BLOCKED
  ARCHIVED
}

enum FurnishingType {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum AmenityCategory {
  BASIC
  SECURITY
  LIFESTYLE
  SPORTS
  POWER_BACKUP
  WATER_SUPPLY
  PG_FACILITY
}

enum ChannelPartnerStatus {
  PENDING
  ACTIVE
  INACTIVE
  REMOVED
}

enum DocumentType {
  AADHAR
  PAN
  RERA_CERTIFICATE
  GST_CERTIFICATE
  BUSINESS_LICENSE
  PROPERTY_DEED
  OTHER
}

enum DocumentVerificationStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum CallStatus {
  INITIATED
  RINGING
  COMPLETED
  MISSED
  NO_ANSWER
  BUSY
}

enum AdvertisementType {
  BANNER
  PROMOTED_LISTING
  PROMOTED_PROJECT
  SPONSORED
}

/////////////////////////
// MODELS
/////////////////////////

model User {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String   @unique
  phone    String   @unique
  password String?
  role     UserRole @default(BUYER)

  // Verification status
  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)
  isBlocked       Boolean @default(false)
  avatar          String?
  lastLogin       DateTime?

  lastLatitude    Float?
  lastLongitude   Float?
  lastLocationAt  DateTime?

  // KYC Details
  kyc KycDetails?

  locationLogs      LocationLog[]

  profile           Profile?
  listings          Listing[]
  subscriptions     Subscription[]
  projects          Project[]
  listingFavorites  ListingFavorite[]
  listingLikes      ListingLike[]
  listingComments   ListingComment[]
  listingReviews    ListingReview[]

  leadsAsBuyer Lead[] @relation("BuyerLeads")
  leadsAsOwner Lead[] @relation("OwnerLeads")

  reviewsGiven    Review[] @relation("Reviewer")
  reviewsReceived Review[] @relation("ReviewTarget")

  // Builder ↔ Channel partner links (builder side)
  channelPartnerLinksAsBuilder BuilderChannelPartner[] @relation("BuilderChannelPartners")
  // Channel partner side
  builderLinksAsChannelPartner BuilderChannelPartner[] @relation("ChannelPartnerBuilders")

  documentVerifications DocumentVerification[]

  callsAsCaller   Call[]    @relation("CallCaller")
  callsAsCallee   Call[]    @relation("CallCallee")
  messagesSent    Message[] @relation("MessageSender")
  messagesReceived Message[] @relation("MessageReceiver")

  advertisementsCreated Advertisement[] @relation("AdvertisementCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

type KycDetails {
  // Aadhar Card
  aadharNumber     String?
  aadharName       String?
  aadharDob        String?
  aadharDocUrl     String?
  isAadharVerified Boolean @default(false)
  aadharVerifiedAt DateTime?

  // PAN Card
  panNumber       String?
  panName         String?
  panDocUrl       String?
  isPanVerified   Boolean @default(false)
  panVerifiedAt   DateTime?

  // Overall KYC Status
  kycStatus     KycStatus @default(PENDING)
  kycRemarks    String?
  kycVerifiedAt DateTime?
  kycVerifiedBy String?
}

enum KycStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

model Otp {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  phone     String
  otp       String
  name      String
  password  String
  role      UserRole @default(BUYER)
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([phone])
  @@index([expiresAt])
}

model Project {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String @unique
  description String
  city        String
  locality    String
  latitude    Float
  longitude   Float

  builderId String @db.ObjectId
  builder   User   @relation(fields: [builderId], references: [id])

  totalUnits     Int?
  possessionDate DateTime?
  reraNumber     String?

  listings       Listing[]
  advertisements Advertisement[]

  createdAt DateTime @default(now())
}

/// Links a builder (User) to a channel partner (User). A builder can have many channel partners; a channel partner can work with many builders.
model BuilderChannelPartner {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  builderId         String @db.ObjectId
  channelPartnerId String @db.ObjectId
  status            ChannelPartnerStatus @default(PENDING)

  commissionRatePercent Float?
  notes                String?
  invitedAt            DateTime @default(now())
  activatedAt          DateTime?

  builder         User @relation("BuilderChannelPartners", fields: [builderId], references: [id], onDelete: Cascade)
  channelPartner User @relation("ChannelPartnerBuilders", fields: [channelPartnerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([builderId, channelPartnerId])
  @@index([builderId])
  @@index([channelPartnerId])
  @@index([status])
}

/// User-submitted documents for verification (Aadhar, PAN, RERA, GST, etc.). Tracks status and admin review.
model DocumentVerification {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId       String @db.ObjectId
  documentType DocumentType
  documentName String?  // e.g. "Aadhar front", "RERA certificate"
  documentUrl  String
  status       DocumentVerificationStatus @default(PENDING)

  submittedAt DateTime @default(now())
  verifiedAt  DateTime?
  verifiedBy  String?   @db.ObjectId // Admin user who verified/rejected
  remarks     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([documentType])
}

model Listing {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String @unique
  description String

  price        Float
  pricePerSqft Float?
  listingType  ListingType
  propertyType PropertyType
  condition    PropertyCondition?
  status       ListingStatus @default(ACTIVE)

  bedrooms    Int?
  bathrooms   Int?
  balconies   Int?
  floor       Int?
  totalFloors Int?

  area        Float?
  carpetArea  Float?
  builtUpArea Float?

  furnishing FurnishingType?
  facing     String?

  city      String
  locality  String
  state     String
  pincode   String?
  latitude  Float
  longitude Float

  isVerified  Boolean @default(false)
  isFeatured  Boolean @default(false)
  boostExpiry DateTime?
  expiryDate  DateTime?
  deletedAt   DateTime?
  views       Int      @default(0)
  clicks      Int      @default(0)

  ownerId String @db.ObjectId
  owner   User   @relation(fields: [ownerId], references: [id])

  projectId String?  @db.ObjectId
  project   Project? @relation(fields: [projectId], references: [id])

  images          ListingImage[]
  amenities       AmenityOnListing[]
  leads           Lead[]
  calls           Call[]
  messages        Message[]
  advertisements  Advertisement[]
  favorites       ListingFavorite[]
  likes           ListingLike[]
  comments        ListingComment[]
  reviews         ListingReview[]

  rentCharges RentCharges?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Rent and extra charges (for RENT/LEASE listings and PG/HOSTEL). Optional on Listing.
type RentCharges {
  monthlyRent            Float?   // same as price for rent; can override for display
  securityDeposit        Float?
  maintenanceCharge     Float?
  electricityIncluded   Boolean?
  electricityCharge     Float?
  waterIncluded         Boolean?
  foodIncluded          Boolean?  // PG/HOSTEL
  foodCharges           Float?    // PG/HOSTEL monthly
  laundryIncluded       Boolean?
  otherChargesDescription String?
}

model ListingReview {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  listingId String   @db.ObjectId
  userId    String   @db.ObjectId
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
}

model ListingComment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  listingId String   @db.ObjectId
  userId    String   @db.ObjectId
  content   String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model ListingFavorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  listingId String   @db.ObjectId
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
}

model ListingLike {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  listingId String   @db.ObjectId
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
}

model Lead {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  listingId String @db.ObjectId
  buyerId   String @db.ObjectId
  ownerId   String @db.ObjectId

  message String?
  source  LeadSource
  status  LeadStatus @default(NEW)

  createdAt DateTime @default(now())

  listing  Listing   @relation(fields: [listingId], references: [id])
  buyer    User      @relation("BuyerLeads", fields: [buyerId], references: [id])
  owner    User      @relation("OwnerLeads", fields: [ownerId], references: [id])
  calls    Call[]
  messages Message[]
}

/// Call between two users (e.g. buyer → agent/builder/channel partner). Premium roles (agent, builder, channel partner) receive calls.
model Call {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  callerId String @db.ObjectId
  calleeId String @db.ObjectId
  listingId String?  @db.ObjectId
  leadId   String?  @db.ObjectId

  durationSeconds Int?
  status          CallStatus @default(INITIATED)

  caller  User     @relation("CallCaller", fields: [callerId], references: [id], onDelete: Cascade)
  callee  User     @relation("CallCallee", fields: [calleeId], references: [id], onDelete: Cascade)
  listing Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([callerId])
  @@index([calleeId])
  @@index([listingId])
  @@index([leadId])
  @@index([createdAt])
}

/// Direct message between two users (e.g. buyer ↔ agent/builder/channel partner). Premium roles receive messages.
model Message {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  senderId   String  @db.ObjectId
  receiverId String  @db.ObjectId
  content    String
  listingId  String? @db.ObjectId
  leadId     String? @db.ObjectId

  readAt DateTime?

  sender   User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User    @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  listing  Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  lead     Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([listingId])
  @@index([leadId])
  @@index([createdAt])
}

model LocationLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  latitude  Float
  longitude Float
  accuracy  Float?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

/// Promoted content: banners, promoted listings/projects, sponsored ads. Shown on home, listing pages, etc.
model Advertisement {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  title       String
  type        AdvertisementType
  imageUrl    String
  targetUrl   String?  // optional; for PROMOTED_* type often derived from listing/project slug
  description String?

  listingId String? @db.ObjectId
  projectId String? @db.ObjectId
  createdById String? @db.ObjectId

  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  impressions Int @default(0)
  clicks      Int @default(0)

  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User?    @relation("AdvertisementCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
  @@index([startDate])
  @@index([endDate])
  @@index([listingId])
  @@index([projectId])
}

/// Catalog of subscription plans (price, billing, features). Users subscribe via Subscription with plan = PlanType.
model SubscriptionPlan {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  planType    PlanType @unique
  name        String
  slug        String   @unique
  description String?

  priceAmount   Float
  priceCurrency String  @default("INR")
  billingInterval BillingInterval @default(MONTHLY)

  /// Comma or newline-separated feature list, or JSON string
  features   String?
  maxListings Int?   // null = unlimited for FREE, or plan limit
  isActive   Boolean @default(true)
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Subscription {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  userId String   @db.ObjectId
  plan   PlanType
  expiry DateTime
  active Boolean  @default(true)

  user User @relation(fields: [userId], references: [id])
}

model ListingImage {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  listingId String @db.ObjectId
  url       String
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id])
}

model Amenity {
  id       String          @id @default(auto()) @map("_id") @db.ObjectId
  name     String          @unique
  icon     String?
  category AmenityCategory

  listings AmenityOnListing[]
}

model AmenityOnListing {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  listingId String @db.ObjectId
  amenityId String @db.ObjectId

  isHighlighted Boolean  @default(false)
  verified      Boolean  @default(true)
  createdAt     DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id])
  amenity Amenity @relation(fields: [amenityId], references: [id])

  @@unique([listingId, amenityId])
}

model Profile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId

  bio             String?
  companyName     String?
  designation     String?
  experienceYears Int?

  reraNumber String?
  gstNumber  String?

  address String?
  city    String?
  state   String?
  pincode String?

  website     String?
  facebookUrl String?
  linkedinUrl String?

  isReraVerified    Boolean @default(false)
  isCompanyVerified Boolean @default(false)

  rating       Float @default(0)
  totalReviews Int   @default(0)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  rating    Int
  comment   String?

  reviewerId String @db.ObjectId
  userId     String @db.ObjectId

  reviewer User @relation("Reviewer", fields: [reviewerId], references: [id])
  user     User @relation("ReviewTarget", fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
